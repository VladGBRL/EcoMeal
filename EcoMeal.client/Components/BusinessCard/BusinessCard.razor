@namespace EcoMeal.client.Components.BusinessCard
@using EcoMeal.client.Components.BusinessDeleteButton
@using Microsoft.AspNetCore.Components.Authorization



<div class="card border-success-subtle shadow-sm h-100">
    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <span class="badge bg-success-subtle text-success-emphasis">@Business.BusinessTypeName</span>
        </div>
        <h5 class="card-title text-success">@Business.Name</h5>
        <p class="card-text text-muted flex-grow-1">@Business.Description</p>
        <div class="small text-muted mb-3">
            <div class="d-flex align-items-center mb-1">
                <i class="bi bi-geo-alt-fill text-success me-2"></i> @Business.Address
            </div>
            <div class="d-flex align-items-center">
                <i class="bi bi-telephone-fill text-success me-2"></i> @Business.Contact
            </div>
        </div>

        <div class="d-flex gap-2 mt-auto">
            <a href="/business/@Business.BusinessId" class="btn btn-outline-success btn-sm flex-grow-1">View Details</a>
            <AuthorizeView Roles="Admin">
                <BusinessDeleteButton BusinessId="@Business.BusinessId" OnDeleted="OnDeleted" />
            </AuthorizeView>
        </div>
    </div>
</div>