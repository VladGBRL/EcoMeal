@page "/orders"
@namespace EcoMeal.client.Components.Pages.Orders

<PageTitle>My Orders</PageTitle>
<div class="container">
    <h1>My Orders</h1>

    @if(MyOrders is null){
        <p>Loading...</p>
    }else if(!MyOrders.Any()){
        <div class="alert">
            You don't have any orders yet.
        </div>

    }else{

        <div class="row g-3">
            @foreach(var order in MyOrders){
                <div class="col-12 mb-3">
                    <div class="card shadow-sm border-success-subtle">
                        <div class="card-body p-4">
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                                <div>
                                    <h4 class="card-title text-success fw-bold mb-1">@order.PackageName</h4>
                                    <p class="text-muted mb-0 small">
                                        <i class="bi bi-shop me-1 text-success"></i>@order.BusinessName
                                    </p>
                                </div>
                                <div class="d-flex flex-row flex-sm-column align-items-center align-items-sm-end justify-content-between w-100 w-sm-auto border-top border-sm-0 pt-2 pt-sm-0 mt-2 mt-sm-0 gap-2">
                                    <span class="badge rounded-pill bg-success-subtle text-success-emphasis">@order.Status</span>
                                    <div class="d-flex flex-column align-items-sm-end text-end">
                                        <div class="fw-bold text-success fs-5">@order.Price.ToString("0.00") RON</div>
                                        <div class="text-muted small" style="font-size: 0.75rem;">
                                            <i class="bi bi-calendar3 me-1"></i>@order.Date.ToString("dd.MM.yyyy HH:mm")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>