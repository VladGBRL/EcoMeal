@page "/business/{BusinessId:int}/addPackage"
@page "/business/{BusinessId:int}/packages/{PackageId:int}/edit"
@using EcoMeal.client.Models
@rendermode InteractiveServer

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4 p-sm-5">
                    <h2 class="text-success mb-4 fw-bold text-center">@PageTitle</h2>
                    
                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert alert-success mb-4 shadow-sm">@StatusMessage</div>
                    }

                    <EditForm Model="PackageAddModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small mb-4" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nume</label>
                            <InputText class="form-control" @bind-Value="PackageAddModel.Name" placeholder="Surplus Lunch Bag" />
                            <ValidationMessage For="@(() => PackageAddModel.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Descriere</label>
                            <InputTextArea class="form-control" @bind-Value="PackageAddModel.Description" placeholder="Contains sandwiches, fruits and a pastry..." rows="3" />
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-6 mb-3">
                                <label class="form-label fw-semibold">Pret (RON)</label>
                                <InputNumber class="form-control" @bind-Value="PackageAddModel.Price" placeholder="0" />
                            </div>

                            <div class="col-12 col-sm-6 mb-3">
                                <label class="form-label fw-semibold">Tip pachet</label>
                                <InputSelect @bind-Value="PackageAddModel.PackageTypeId" class="form-select">
                                    <option value="0" disabled>Choose package type...</option>
                                    @foreach (var packageType in PackageTypes)
                                    {
                                        <option value="@packageType.PackageTypeId">@packageType.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-6 mb-3">
                                <label class="form-label fw-semibold">Start Pick-up</label>
                                <InputDate @bind-Value="PackageAddModel.StartPickup" Type="InputDateType.DateTimeLocal" class="form-control" />
                            </div>

                            <div class="col-12 col-sm-6 mb-4">
                                <label class="form-label fw-semibold">End Pick-up</label>
                                <InputDate @bind-Value="PackageAddModel.EndPickup" Type="InputDateType.DateTimeLocal" class="form-control" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 py-2 fw-semibold">@ButtonText</button>
                            <a href="/business/@BusinessId" class="btn btn-outline-secondary px-4 py-2 fw-semibold">Cancel</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>