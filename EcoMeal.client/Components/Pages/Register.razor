@page "/register"
@using EcoMeal.client.Models
@using EcoMeal.client.Models.Auth
@using EcoMeal.client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4 p-sm-5">
                    <h3 class="text-center text-success mb-4 fw-bold">Register</h3>
                    
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mb-4">@errorMessage</div>
                    }

                    <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <InputText class="form-control" @bind-Value="registerModel.Email" placeholder="name@example.com" />
                            <ValidationMessage For="() => registerModel.Email" class="text-danger small" />
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-6 mb-3">
                                <label class="form-label fw-semibold">Password</label>
                                <InputText type="password" class="form-control" @bind-Value="registerModel.Password" placeholder="••••••••" />
                                <ValidationMessage For="() => registerModel.Password" class="text-danger small" />
                            </div>

                            <div class="col-12 col-sm-6 mb-3">
                                <label class="form-label fw-semibold">Confirm Password</label>
                                <InputText type="password" class="form-control" @bind-Value="registerModel.ConfirmPassword" placeholder="••••••••" />
                                <ValidationMessage For="() => registerModel.ConfirmPassword" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <InputText class="form-control" @bind-Value="registerModel.Name" placeholder="Your name or business name" />
                            <ValidationMessage For="() => registerModel.Name" class="text-danger small" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Contact Info</label>
                            <InputText class="form-control" @bind-Value="registerModel.Contact" placeholder="Phone or email" />
                            <ValidationMessage For="() => registerModel.Contact" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">Register</button>
                    </EditForm>

                    <div class="text-center mt-4">
                        <p class="mb-0 text-muted small">Already have an account? <a href="/login" class="text-success fw-bold text-decoration-none">Login</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterModel registerModel { get; set; } = new();

    private string? errorMessage;

    private async Task HandleRegister()
    {
        var result = await AuthService.RegisterAsync(registerModel.Email, registerModel.Password, registerModel.Name, registerModel.Contact);

        if (result.Success)
        {
            ToastService.ShowSuccess("Registration successful! You can now log in.");
            Navigation.NavigateTo("/login");
        }
        else
        {
            errorMessage = result.ErrorMessage;
            ToastService.ShowError(errorMessage ?? "Registration failed.");
        }
    }
}
