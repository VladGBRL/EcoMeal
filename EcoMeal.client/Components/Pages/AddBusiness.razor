@page "/business/add"
@page "/business/{Id:int}/edit"
@using EcoMeal.client.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4 p-sm-5">
                    <h2 class="text-success mb-4 fw-bold text-center">@PageTitle</h2>
                    
                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert alert-success mb-4 shadow-sm">@StatusMessage</div>
                    }

                    <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small mb-4" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <InputText class="form-control" @bind-Value="Model.Name" placeholder="EcoMeal Restaurant" />
                            <ValidationMessage For="@(() => Model.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Address</label>
                            <InputText class="form-control" @bind-Value="Model.Address" placeholder="123 Green Street" />
                            <ValidationMessage For="@(() => Model.Address)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact</label>
                            <InputText class="form-control" @bind-Value="Model.Contact" placeholder="+40 700 000 000" />
                            <ValidationMessage For="@(() => Model.Contact)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <InputTextArea class="form-control" @bind-Value="Model.Description" placeholder="Tell us about your surplus food..." rows="3" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Business type</label>
                            <InputSelect @bind-Value="Model.BusinessTypeId" class="form-select">
                                <option value="0" disabled>Choose business type...</option>
                                @foreach (var type in BusinessTypes)
                                {
                                    <option value="@type.BusinessTypeId">@type.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => Model.BusinessTypeId)" class="text-danger small" />
                        </div>

                        <div class="mb-4">
                            <MapPicker AccessToken="@MapboxToken"
                                       InitialLat="@Model.Latitude"
                                       InitialLng="@Model.Longitude"
                                       OnLocationChanged="@HandleLocationChanged"
                                       OnLocationCleared="@HandleLocationCleared" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 py-2 fw-semibold">@ButtonText</button>
                            <a href="/" class="btn btn-outline-secondary px-4 py-2 fw-semibold">Cancel</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>
