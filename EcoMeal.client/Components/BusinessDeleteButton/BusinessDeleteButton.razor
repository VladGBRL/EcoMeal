@namespace EcoMeal.client.Components.BusinessDeleteButton

<button type="button" class="btn btn-danger btn-sm" @onclick="HandleDeleteAsync" @onclick:stopPropagation="true" disabled="@_isDeleting">
    @if (_isDeleting)
    {
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
    }
    else
    {
        <i class="bi bi-trash"></i>
        <span>Delete</span>
    }
</button>

@if (_hasError)
{
    <div class="text-danger small mt-1">Cannot remove the business.</div>
}

@if (_hasSuccess)
{
    <div class="text-success small mt-1">Business removed.</div>
}