@namespace EcoMeal.client.Components.BusinessList
@using EcoMeal.client.Components.BusinessCard
@using EcoMeal.client.Models

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Businesses</h2>
    <a href="/business/add" class="btn btn-primary">+ Add business</a>
</div>

@if (Businesses is null)
{
    <p>Loading...</p>
}
else if (Businesses.Count == 0)
{
    <p>No business found.</p>
}
else
{
    <div class="businessList">
        <div class="row g-4">
            @foreach (BusinessModel business in Businesses)
            {
                <div class="col-sm" @key="business.BusinessId">
                    <BusinessCard Business="business" OnDeleted="HandleBusinessDeleted" />
                </div>
            }
        </div>
    </div>
}