@using EcoMeal.client.Components.Map
@rendermode InteractiveServer

<div class="map-picker-wrapper mb-3">
    <label class="form-label fw-semibold">
        <i class="bi bi-geo-alt-fill text-success me-1"></i>
        Pick Location on Map
        <span class="text-muted fw-normal small ms-1">(click or drag marker)</span>
    </label>

    <div id="@_containerId"
         style="width: 100%; height: 380px; border-radius: 0.5rem; overflow: hidden; border: 1px solid #dee2e6;"
         class="shadow-sm">
    </div>

    @if (_lat.HasValue && _lng.HasValue)
    {
        <div class="mt-2 d-flex align-items-center gap-3 small text-muted">
            <span><i class="bi bi-crosshair2 me-1 text-success"></i>
                <strong>Lat:</strong> @_lat.Value.ToString("F6")
            </span>
            <span>
                <strong>Lng:</strong> @_lng.Value.ToString("F6")
            </span>
            <button type="button" class="btn btn-link btn-sm text-danger p-0 ms-auto"
                    @onclick="ClearLocation" title="Clear location">
                <i class="bi bi-x-circle"></i> Clear
            </button>
        </div>
    }
    else
    {
        <div class="mt-2 small text-muted fst-italic">
            <i class="bi bi-info-circle me-1"></i>No location selected. Click the map to pin a location.
        </div>
    }
</div>
